   RowBox[{"CordicVectorN", "[", 
    RowBox[{"vec_", ",", "n_"}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"i", ",", "acc"}], "}"}], ",", 
     RowBox[{
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"i", "=", "0"}], ";", 
         RowBox[{"acc", "=", "vec"}]}], ",", 
        RowBox[{"i", "<", "n"}], ",", 
        RowBox[{"i", "++"}], ",", 
        RowBox[{"acc", "=", 
         RowBox[{"CordicVector", "[", 
          RowBox[{"acc", ",", "i"}], "]"}]}]}], "]"}], ";", "acc"}]}], 
    "]"}]}], ";"}]], "Input",
