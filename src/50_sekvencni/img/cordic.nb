Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CordicKfactor", "[", "n_", "]"}], ":=", 
   RowBox[{"Product", "[", 
    RowBox[{
     FractionBox["1", 
      RowBox[{"Sqrt", "[", 
       RowBox[{"1", "+", 
        SuperscriptBox["2", 
         RowBox[{
          RowBox[{"-", "2"}], "i"}]]}], "]"}]], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "0", ",", 
       RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9799106902589073`*^9, 3.979910699602511*^9}, {
