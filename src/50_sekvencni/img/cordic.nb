Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CordicVector", "[", 
    RowBox[{"vec_", ",", "i_"}], "]"}], ":=", 
   RowBox[{"Block", "[", 
    RowBox[{
     RowBox[{"{", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"x", "=", 
        RowBox[{"vec", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", 
       RowBox[{"y", "=", 
        RowBox[{"vec", "[", 
         RowBox[{"[", "2", "]"}], "]"}]}], ",", 
       RowBox[{"tanphi", "=", 
        SuperscriptBox["2", 
         RowBox[{"-", "i"}]]}], ",", "\[IndentingNewLine]", 
       RowBox[{"d", "=", 
        RowBox[{"-", 
         RowBox[{"Sign", "[", "y", "]"}]}]}]}], "\[IndentingNewLine]", "}"}], 
     ",", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "-", 
        RowBox[{"d", "*", "tanphi", "*", "y"}]}], ",", 
       RowBox[{"y", "+", 
        RowBox[{"d", "*", "tanphi", "*", "x"}]}]}], "}"}]}], 
    "\[IndentingNewLine]", "]"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.979888661867436*^9, 3.979888663741045*^9}, {
